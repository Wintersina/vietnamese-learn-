# Copy to .env and fill in. The app runs fine without these (text/IPA only).

# Southern-dialect TTS via FPT.AI — sign up at https://fpt.ai/ for a free key.
# 1) create an app on the TTS service, 2) copy its API key here.
FPT_API_KEY=
# Southern (miền Nam) voices: lannhi (female), minhquang (male).
FPT_VOICE=lannhi

# Optional Django overrides
# DJANGO_SECRET_KEY=change-me-in-production
# DJANGO_DEBUG=1
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
